# Copy this file to .env and fill with your real IBM Quantum credentials.
# Do NOT commit .env with real secrets.

IBM_QUANTUM_TOKEN=your_ibm_quantum_api_token_here
IBM_QUANTUM_CRN=your_ibm_quantum_crn_here
IBM_QUANTUM_BACKEND=ibm_torino
IBM_QUANTUM_SHOTS=4096
IBM_QUANTUM_N_Q=16

# Optional: custom overrides for older versions
# IBM_QUANTUM_SHOTS=1024  # v2
# IBM_QUANTUM_SHOTS=2048  # v6
